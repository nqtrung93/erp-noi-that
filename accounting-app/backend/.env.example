# Sao chép file này thành .env và điền giá trị thật. KHÔNG commit .env lên git.
PORT=4100

# PostgreSQL — dùng database RIÊNG, không chung với ERP
DATABASE_URL=postgres://accounting_user:change_me@localhost:5432/accounting

# JWT — phải là chuỗi ngẫu nhiên dài, bí mật
JWT_SECRET=please-change-this-to-a-long-random-secret
JWT_EXPIRES_IN=8h

# Tài khoản admin khởi tạo (chỉ dùng cho seed lần đầu). Mật khẩu sẽ được bcrypt hash.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change_me_now

# CORS origin của frontend
CORS_ORIGIN=http://localhost:5273
